{
  "$schema": "https://opencode.ai/config.json",
  // Load project skills from .agents/skills so opencode and Antigravity share
  // one skill folder (Antigravity reads .agents/). `paths` is additive and
  // does not disable the default .opencode/skills scan.
  "skills": {
    "paths": [".agents/skills"]
  }
}
